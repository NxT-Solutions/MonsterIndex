{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "packageManager": "bun@1.2.17",
    "scripts": {
        "build": "tsc && vite build",
        "dev": "vite",
        "dev:docker": "vite --host 0.0.0.0 --port 5173",
        "i18n:sync": "node ./scripts/sync-locales.mjs",
        "serve:test": "php artisan serve --host=127.0.0.1 --port=8000",
        "test:browser": "playwright test",
        "test:lighthouse": "lhci autorun --config=./lighthouserc.json",
        "quality:smoke": "rm -f public/hot && start-server-and-test serve:test http://127.0.0.1:8000 \"bun run test:browser && bun run test:lighthouse\""
    },
    "dependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@fontsource/oxanium": "^5.2.8",
        "@fontsource/rajdhani": "^5.2.7",
        "@lhci/cli": "^0.15.1",
        "@playwright/test": "^1.58.2",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "playwright-core": "^1.58.2",
        "sonner": "^2.0.7",
        "start-server-and-test": "^2.1.5"
    },
    "devDependencies": {
        "@headlessui/react": "^2.2.9",
        "@inertiajs/react": "^2.3.18",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.2.1",
        "@types/node": "^22.19.15",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^4.7.0",
        "autoprefixer": "^10.4.27",
        "axios": "^1.13.6",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "concurrently": "^9.2.1",
        "laravel-vite-plugin": "^2.1.0",
        "lucide-react": "^0.552.0",
        "postcss": "^8.5.8",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    }
}
