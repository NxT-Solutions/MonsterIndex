{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--headless=new --no-sandbox"
      },
      "url": [
        "http://127.0.0.1:8000/",
        "http://127.0.0.1:8000/login",
        "http://127.0.0.1:8000/monsters/monster-energy-original-500ml",
        "http://127.0.0.1:8000/__smoke/login?role=contributor&redirect=/contribute/monitors",
        "http://127.0.0.1:8000/__smoke/login?role=admin&redirect=/admin"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 1
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 1
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 1
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.01
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
